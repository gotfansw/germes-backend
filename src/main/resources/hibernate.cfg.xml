<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">

<hibernate-configuration>
    <session-factory>
        <!-- Настройки подключения к PostgreSQL -->
        <property name="connection.driver_class">org.postgresql.Driver</property>
        <property name="connection.url">jdbc:postgresql://localhost:5432/germes_db</property>
        <property name="connection.username">postgres</property>
        <property name="connection.password">admin</property>

        <!-- Диалект для PostgreSQL -->
        <property name="dialect">org.hibernate.dialect.PostgreSQLDialect</property>

        <!-- Показывать SQL запросы в консоли -->
        <property name="show_sql">true</property>
        <property name="format_sql">true</property>

        <!-- Автоматическое создание/обновление таблиц -->
        <property name="hibernate.hbm2ddl.auto">update</property>

        <!-- РЕГИСТРАЦИЯ КЛАССОВ (исправлено) -->
        <mapping class="org.example.model.Category"/>
        <mapping class="org.example.model.Product"/>
        <mapping class="org.example.model.CartItem"/>
        <mapping class="org.example.model.Cart"/>
        <mapping class="org.example.model.Order"/>
        <mapping class="org.example.model.OrderItem"/>

    </session-factory>
</hibernate-configuration>
